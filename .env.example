# Copy this file to .env and fill in your values. Never commit .env.

# Groq — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini — https://aistudio.google.com/app/apikey
# Used as daily-quota fallback (tag.py) and for re-tagging error rows (retag_errors.py).
# Use the new AQ.* auth-key format (generated in AI Studio); requires google-genai SDK.
# Legacy AIza.* keys from google-generativeai SDK will NOT work.
GEMINI_API_KEY=your_gemini_api_key_here

# Reddit — https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=spotify-discovery-engine by u/your_username

# Optional tuning
PLAYSTORE_REVIEW_COUNT=3000
GROQ_TAGGING_MODEL=llama-3.1-8b-instant
GROQ_RAG_MODEL=llama-3.3-70b-versatile
